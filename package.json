{
  "name": "@73/kilo-wechat-bridge",
  "version": "0.1.0",
  "description": "Bridge WeChat ClawBot to a local Kilo Code CLI via kilo serve HTTP API",
  "type": "module",
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE.txt"
  ],
  "keywords": [
    "wechat",
    "kilo",
    "kilocode",
    "bridge"
  ],
  "author": "73 <73@oc.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://git.73oc.local/73/wechat-kilocli-bridge.git"
  },
  "private": true,
  "bin": {
    "wechat-bridge-kilo": "bin/wechat-bridge-kilo.mjs",
    "wechat-kilo": "bin/wechat-kilo.mjs",
    "wechat-kilo-start": "bin/wechat-kilo-start.mjs",
    "wechat-setup": "bin/wechat-setup.mjs",
    "wechat-check-update": "bin/wechat-check-update.mjs"
  },
  "scripts": {
    "setup": "node --no-warnings --experimental-strip-types src/wechat/setup.ts",
    "check": "node --no-warnings --experimental-strip-types src/wechat/wechat-channel.ts --check",
    "bridge:kilo": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter kilo",
    "kilo:panel": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter kilo",
    "kilo:start": "node --no-warnings --experimental-strip-types src/companion/local-companion-start.ts --adapter kilo",
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test test",
    "test:bridge": "bun test test/bridge",
    "test:companion": "bun test test/companion",
    "test:wechat": "bun test test/wechat"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.3.2",
    "ajv-formats": "^3.0.1",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
